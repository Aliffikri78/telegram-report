FROM nvidia/cuda:11.8.0-runtime-ubuntu22.04
ENV DEBIAN_FRONTEND=noninteractive PYTHONDONTWRITEBYTECODE=1 PYTHONUNBUFFERED=1
RUN apt-get update && apt-get install -y --no-install-recommends python3 python3-pip python3-venv python3-dev \
    libglib2.0-0 libsm6 libxext6 libxrender1 libgl1 && rm -rf /var/lib/apt/lists/*
WORKDIR /app
COPY requirements.txt ./requirements.txt
RUN python3 -m pip install --upgrade pip && pip install --no-cache-dir -r requirements.txt
COPY app.py report_menu_table.py ./
COPY templates ./templates
COPY static ./static
ENV TZ=Asia/Kuala_Lumpur SAVE_ROOT=/data/photos REPORTS_ROOT=/data/reports PORT=8080
EXPOSE 8080
ENTRYPOINT ["python3","app.py"]
